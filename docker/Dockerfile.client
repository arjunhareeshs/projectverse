FROM node:20-alpine
WORKDIR /app
COPY package.json pnpm-workspace.yaml ./
COPY client/package.json ./client/package.json
RUN corepack enable && corepack prepare pnpm@10.14.0 --activate && pnpm install --frozen-lockfile=false
COPY . .
WORKDIR /app/client
EXPOSE 5173
CMD ["pnpm", "dev", "--host", "0.0.0.0"]
