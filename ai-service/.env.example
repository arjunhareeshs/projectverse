AI_SERVICE_PORT=8000

# LLM (Groq) — required
GROQ_API_KEY=
AI_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
AI_FALLBACK_MODEL=openai/gpt-oss-120b
AI_TEMPERATURE=0.3

# Internal request signing — must match the secret Node signs X-Internal-Token with
INTERNAL_TOKEN_SECRET=
NODE_INTERNAL_URL=http://localhost:4000/api/internal

# RAG / vector store (Stage 3/4). Point at a running Qdrant server (http://localhost:6333) in
# production; a filesystem path (e.g. ./data/qdrant) runs Qdrant embedded, no server needed — fine for dev.
QDRANT_URL=./data/qdrant
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
RERANK_MODEL=BAAI/bge-reranker-v2-m3

# Memory vault (Stage 5/6)
VAULT_ROOT=./data/vaults
JOBS_DB=./data/jobs.sqlite

# Web/browser tools (Stage 7)
DDGS_REGION=wt-wt
PLAYWRIGHT_ALLOWED_DOMAINS=github.com,arxiv.org

# Legacy Phase-1 placeholder endpoints (app/api/inference.py)
OPENAI_API_KEY=
GEMINI_API_KEY=
AI_DEFAULT_PROVIDER=openai
